{
  "name": "brightlite-middleware",
  "version": "1.0.0",
  "description": "Brightlite AI Middleware - Infrastructure-agnostic intake and scheduling",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test:routes": "tsx src/scripts/test-routes.ts",
    "test:routes:mongo": "tsx src/scripts/test-routes.ts --db mongodb",
    "worker:mongo-sync": "tsx src/workers/mongo-sync.worker.ts"
  },
  "keywords": [
    "brightlite",
    "middleware",
    "fastify",
    "ai",
    "scheduling"
  ],
  "author": "Brightlite Media Corporation",
  "license": "ISC",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@fastify/cors": "^10.0.2",
    "@fastify/helmet": "^13.0.1",
    "@fastify/rate-limit": "^10.2.2",
    "@fastify/swagger": "^9.4.2",
    "@fastify/swagger-ui": "^5.2.2",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "ioredis": "^5.10.1",
    "mongodb": "^7.1.1",
    "nodemailer": "^6.10.0",
    "openai": "^4.86.2",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "twilio": "^5.4.5",
    "uuid": "^11.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/nodemailer": "^6.4.17",
    "@types/uuid": "^10.0.0",
    "nodemon": "^3.1.9",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "^5.8.2"
  }
}
