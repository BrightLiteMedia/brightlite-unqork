# ─────────────────────────────────────────────
# Brightlite Middleware – Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# ── Multi-tenancy ──────────────────────────────
# Set to "true" when running as a hosted SaaS serving multiple Unqork clients.
# Each request must carry X-Client-ID + X-API-Key headers (stored in Unqork Connection Manager).
# Set to "false" (default) for a single-client self-hosted deployment — uses CLIENT_* vars below.
MULTI_TENANT=false

# Master key for /admin/clients provisioning endpoints (Brightlite internal only).
# Generate a strong random secret: openssl rand -hex 32
ADMIN_API_KEY=

# ── AI Provider ───────────────────────────────
# Set to "anthropic" or "openai"
AI_PROVIDER=anthropic

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (GPT)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ── OTP Settings ─────────────────────────────
OTP_EXPIRY_SECONDS=300
OTP_LENGTH=6

# ── Twilio (SMS) ─────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+1...

# ── Email (SMTP / SendGrid) ───────────────────
# Provider: "smtp" or "sendgrid"
EMAIL_PROVIDER=sendgrid

# SendGrid
SENDGRID_API_KEY=SG....
EMAIL_FROM=no-reply@yourdomain.com
EMAIL_FROM_NAME=Your Company

# SMTP (alternative to SendGrid)
SMTP_HOST=smtp.yourdomain.com
SMTP_PORT=587
SMTP_USER=...
SMTP_PASS=...

# ── Database ──────────────────────────────────
# Adapter: "postgres" | "mysql" | "mssql" | "mongodb" | "memory"
DB_ADAPTER=memory

# PostgreSQL
POSTGRES_URL=postgresql://user:pass@host:5432/dbname

# MySQL
MYSQL_URL=mysql://user:pass@host:3306/dbname

# MongoDB
MONGO_URL=mongodb://user:pass@host:27017/dbname
MONGO_DB_NAME=
MONGO_READ_PREFERENCE=secondaryPreferred
MONGO_SEARCH_INDEX_SUBMISSIONS=default
MONGO_SEARCH_INDEX_APPOINTMENTS=default
MONGO_SEARCH_INDEX_CLIENTS=default

# Redis front cache / write-behind queue
REDIS_URL=redis://127.0.0.1:6379
REDIS_WRITE_STREAM=mongo:writebehind

# ── Client Config ─────────────────────────────
CLIENT_NAME=Acme Corp
CLIENT_TIMEZONE=America/Chicago

# Appointment Services (comma-separated JSON)
APPOINTMENT_SERVICES=[{"id":"consultation","label":"Consultation","durationMinutes":30},{"id":"demo","label":"Demo","durationMinutes":60},{"id":"support","label":"Support Call","durationMinutes":30}]

# Available days: 0=Sun,1=Mon,...,6=Sat
APPOINTMENT_AVAILABLE_DAYS=1,2,3,4,5
APPOINTMENT_START_TIME=09:00
APPOINTMENT_END_TIME=17:00
APPOINTMENT_SLOT_INTERVAL_MINUTES=30

# Routing rules (who gets notified for each inquiry type)
ROUTING_SALES=sales@yourdomain.com
ROUTING_SUPPORT=support@yourdomain.com
ROUTING_BILLING=billing@yourdomain.com
ROUTING_GENERAL=info@yourdomain.com
